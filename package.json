{
  "name": "sbb-kiosk-ordering",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:api": "tsx server/index.ts",
    "dev:all": "node scripts/dev-all.mjs",
    "serve:all": "node scripts/serve-all.mjs",
